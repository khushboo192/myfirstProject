<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FreshCart - Grocery Store</title>
  <style>
    /* Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f8f9fa;
      color: #333;
    }
    /* Header */
    header {
      background: #fff;
      padding: 15px 50px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
.srch{
font-family: 'Times New Roman', Times, serif;
width:200px;
height:40px;
background: transparent;
border: 1px solid#ff7200;
margin-top:13px ;
color:#54872a ;
border-right:none ;
font-size:16px ;
float: left;
border-bottom-left-radius:5px; border-top-left-radius:5px ;
}
    .logo {
      font-size: 22px;
      font-weight: bold;
      color: #28a745;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 20px;
    }

    nav ul li a {
      text-decoration: none;
      color: #333;
      font-weight: 500;
      transition: 0.3s;
    }

    nav ul li a:hover {
      color: #28a745;
    }

    /* Hero Section */
    .hero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 60px 50px;
      background: #e9f9ef;
    }

    .hero-text {
      max-width: 50%;
    }
    .hero-text h4 {
      background: #ffc107;
      display: inline-block;
      padding: 5px 10px;
      border-radius: 5px;
      font-size: 14px;
    }

    .hero-text h1 {
      font-size: 40px;
      margin: 20px 0;
      color: #212529;
    }

    .hero-text p {
      margin-bottom: 20px;
      color: #555;
    }

    .btn {
      background: #212529;
      color: #fff;
      padding: 12px 20px;
      text-decoration: none;
      border-radius: 6px;
      font-size: 16px;
      transition: 0.3s;
    }

    .btn:hover {
      background: #28a745;
    }

    .hero img {
        height: 250px;
      width: 250px;
        border-radius: 50%; 
        background: #dfdfdf; 
    }

    /* Featured Categories */
    .categories {
      padding: 40px 50px;
    }

    .categories h2 {
      margin-bottom: 20px;
      font-size: 20px;
    }

    .category-list {
      display: flex;
      gap: 20px;
    }

    .category {
      flex: 1;
      background: #fff;
      padding: 20px;
      text-align: center;
      border-radius: 12px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      transition: 0.3s;
    }

    .category:hover {
      transform: translateY(-5px);
    }
    :root{
      --bg:#0b1020;           /* dark header */
      --brand:#5b7cfa;        /* primary */
      --brand-2:#6e59f5;
      --ink:#111827;          /* text */
      --muted:#6b7280;
      --card:#ffffff;
      --soft:#f3f4f6;
      --ring:rgba(91,124,250,.25);
      --radius:18px;
    }

    *{box-sizing:border-box}
    html,body{margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:var(--ink);background:#f8fafc}

    /* --- Header / Nav --- */
    .topbar{
      background:linear-gradient(90deg,var(--bg),#12193a);
      color:#fff;
      position:sticky;top:0;z-index:20;
      border-bottom:1px solid rgba(255,255,255,.08)
    }
    .container{
      width:min(1200px,92vw);
      margin-inline:auto;
    }
    .nav{
      display:flex;align-items:center;gap:18px;justify-content:space-between;
      padding:16px 0;
    }
    .brand{
      display:flex;align-items:center;gap:10px;font-weight:800;letter-spacing:.3px
    }
    .brand-logo{
      width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--brand),var(--brand-2));
      display:grid;place-items:center;color:#fff;font-size:18px;box-shadow:0 8px 24px -8px var(--ring)
    }
    .actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
    .search{
      flex:1 1 420px;display:flex;gap:8px;background:#0f1731;border:1px solid rgba(255,255,255,.08);
      border-radius:999px;padding:8px 12px
    }
    .search input,.filter select{
      appearance:none;border:0;background:transparent;color:#fff;outline:none;width:100%;
    }
    .filter select{padding:10px 14px;border-radius:999px;background:#0f1731;border:1px solid rgba(255,255,255,.1)}
    .cart-btn{
      position:relative;border:0;background:linear-gradient(135deg,var(--brand),var(--brand-2));
      color:#fff;padding:10px 16px;border-radius:999px;cursor:pointer;font-weight:600;
      box-shadow:0 10px 30px -10px var(--ring)
    }
    .badge{
      position:absolute;top:-6px;right:-6px;background:#10b981;color:#001;min-width:22px;height:22px;
      border-radius:999px;display:grid;place-items:center;font-size:12px;font-weight:800;border:2px solid #fff
    }

    /* --- Hero --- */
    .hero{
      background:linear-gradient(180deg,#eef2ff,transparent);
      padding:28px 0 6px;
    }
    .hero .panel{
      display:grid;grid-template-columns:1.2fr .8fr;gap:20px;align-items:center
    }
    .hero .card{
      background:var(--card);border-radius:var(--radius);padding:24px;
      box-shadow:0 10px 30px -20px rgba(0,0,0,.25);
    }
    .hero h1{margin:0 0 10px;font-size:clamp(22px,3.4vw,36px)}
    .hero p{margin:0;color:var(--muted)}
    .note{
      background:#eef2ff;border:1px dashed #c7d2fe;color:#3730a3;padding:10px 12px;border-radius:12px
    }

    /* --- Product grid --- */
    .section{padding:22px 0}
    .grid{
      display:grid;grid-template-columns:repeat(12,1fr);gap:18px
    }
    .col-3{grid-column:span 3}
    @media (max-width:1000px){.col-3{grid-column:span 4}}
    @media (max-width:720px){.hero .panel{grid-template-columns:1fr}.col-3{grid-column:span 6}}
    @media (max-width:520px){.col-3{grid-column:span 12}}

    .product{
      display:flex;flex-direction:column;background:var(--card);border-radius:16px;overflow:hidden;
      border:1px solid #e5e7eb
    }
    .thumb{aspect-ratio:4/3;background:#eef2ff;display:grid;place-items:center;font-weight:700;color:#6366f1}
    .p-body{padding:14px}
    .title{font-size:15px;font-weight:700;margin:2px 0 6px}
    .price{display:flex;align-items:center;gap:10px;margin:6px 0 12px}
    .price .old{color:#9ca3af;text-decoration:line-through}
    .rating{font-size:12px;color:#f59e0b}
    .btn{
      appearance:none;border:0;background:#111827;color:#fff;padding:10px 12px;border-radius:12px;cursor:pointer;font-weight:600;
      transition:transform .04s ease;
    }
    
    /* --- Cart drawer --- */
    .drawer{
      position:fixed;inset:0;pointer-events:none;
    }
    .drawer.open{pointer-events:auto}
    .overlay{
      position:absolute;inset:0;background:rgba(0,0,0,.4);opacity:0;transition:opacity .2s
    }
    .drawer.open .overlay{opacity:1}
    .panel{
      position:absolute;top:0;right:0;width:min(420px,92vw);height:100%;
      background:#fff;border-left:1px solid #e5e7eb;border-radius:18px 0 0 18px;
      transform:translateX(100%);transition:transform .25s
    }
    .drawer.open .panel{transform:none}
    .panel header{display:flex;justify-content:space-between;align-items:center;padding:16px 18px;border-bottom:1px solid #e5e7eb}
    .cart-items{padding:12px;height:calc(100% - 180px);overflow:auto}
    .cart-row{display:grid;grid-template-columns:64px 1fr auto;gap:12px;align-items:center;padding:10px;border-radius:12px;border:1px solid #eef2f7;margin-bottom:10px;background:#fafafa}
    .qty{display:inline-flex;border:1px solid #d1d5db;border-radius:10px;overflow:hidden}
    .qty button{border:0;background:#f3f4f6;padding:6px 10px;cursor:pointer}
    .qty input{width:38px;border:0;text-align:center}
    .panel footer{border-top:1px solid #e5e7eb;padding:14px 18px;background:#fafafa}
    .totals{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
    .checkout{display:grid;gap:10px}

    /* --- Forms --- */
    input[type="text"], input[type="email"]{
      width:100%;padding:10px 12px;border:1px solid #d1d5db;border-radius:10px;outline:0
    }
    .pill{display:inline-flex;gap:8px;align-items:center;font-size:12px;background:#ecfeff;color:#155e75;
      border:1px solid #a5f3fc;padding:6px 10px;border-radius:999px};

#Add-to-cart{
width: 200px;
background:#7952B3;
color:purple;
font-size:15px ;
/* padding:15px 40px;
border:#652cc5 ; */
border-radius:10px ;
transition:0.3s ;

}
.Add-to-cart:hover{
background-color:#652cc5 ;
}

body {
      font-family: Arial, sans-serif;
      margin: 30px;
    }

    /* ⭐ Star Rating */
    .stars {
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .stars input {
      display: none;
    }
    .stars label {
      font-size: 24px;
      color: lightgray;
      cursor: pointer;
    }
    .stars input:checked ~ label,
    .stars label:hover,
    .stars label:hover ~ label {
      color: gold;
    }

    .rating-text {
      margin-top: 5px;
      color: #555;
      font-size: 14px;
    }
  </style>
</head>
